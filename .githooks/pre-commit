#!/bin/bash
#
# Pre-commit hook for agentbase data isolation
#
# Prevents accidental commits of:
# - Extension files (should be in their own repos)
# - Data files (.db, .sqlite, credentials, etc.)
# - Large binary files
#
# Install: ./scripts/setup-git-hooks.sh

set -e

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

ERRORS=0
WARNINGS=0

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

echo "Running pre-commit checks..."

# Check 1: Data file patterns (block)
DATA_PATTERNS='\.db$|\.sqlite$|\.sqlite3$|credentials.*\.json$|\.pem$|\.key$'
DATA_FILES=$(echo "$STAGED_FILES" | grep -E "$DATA_PATTERNS" || true)
if [ -n "$DATA_FILES" ]; then
    echo -e "${RED}ERROR: Data/credential files should not be committed.${NC}"
    echo "Blocked files:"
    echo "$DATA_FILES" | sed 's/^/  - /'
    ERRORS=$((ERRORS + 1))
fi

# Check 3: .env file (block)
ENV_FILES=$(echo "$STAGED_FILES" | grep -E '^\.env$|^\.env\.local$|^\.env\.[^e]' || true)
if [ -n "$ENV_FILES" ]; then
    echo -e "${RED}ERROR: Environment files should not be committed.${NC}"
    echo "Blocked files:"
    echo "$ENV_FILES" | sed 's/^/  - /'
    ERRORS=$((ERRORS + 1))
fi

# Check 4: Large files (warn for >1MB, block for >10MB)
for file in $STAGED_FILES; do
    if [ -f "$file" ]; then
        SIZE=$(wc -c < "$file" 2>/dev/null || echo 0)
        SIZE_MB=$((SIZE / 1048576))
        if [ "$SIZE" -gt 10485760 ]; then
            echo -e "${RED}ERROR: File exceeds 10MB limit: $file (${SIZE_MB}MB)${NC}"
            ERRORS=$((ERRORS + 1))
        elif [ "$SIZE" -gt 1048576 ]; then
            echo -e "${YELLOW}WARNING: Large file staged: $file (${SIZE_MB}MB)${NC}"
            WARNINGS=$((WARNINGS + 1))
        fi
    fi
done

# Check 5: Common data file extensions (warn)
WARN_PATTERNS='\.csv$|\.xlsx$|\.xls$|\.zip$|\.tar\.gz$|\.parquet$'
WARN_FILES=$(echo "$STAGED_FILES" | grep -E "$WARN_PATTERNS" || true)
if [ -n "$WARN_FILES" ]; then
    echo -e "${YELLOW}WARNING: Data file extensions detected. Verify these should be committed:${NC}"
    echo "$WARN_FILES" | sed 's/^/  - /'
    WARNINGS=$((WARNINGS + 1))
fi

# Check 6: Private-terms scan (optional, local-only denylist)
#
# Keeps YOUR sensitive vocabulary (client names, internal hostnames,
# usernames, project codenames) out of commits. Create the file
#   <git-dir>/private-terms.txt        (i.e. .git/private-terms.txt)
# with one term per line ('#' comments allowed). Terms are matched
# case-insensitively as fixed strings against added lines and staged
# file paths. The file lives inside .git/, so it is never committed,
# never shipped, and is shared automatically by all worktrees.
TERMS_FILE="$(git rev-parse --git-common-dir)/private-terms.txt"
if [ -f "$TERMS_FILE" ]; then
    TERMS=$(grep -vE '^[[:space:]]*#|^[[:space:]]*$' "$TERMS_FILE" || true)
    if [ -n "$TERMS" ]; then
        ADDED_LINES=$(git diff --cached --diff-filter=ACM | grep -E '^\+' | grep -vE '^\+\+\+' || true)
        while IFS= read -r term; do
            [ -z "$term" ] && continue
            HIT_LINES=$(printf '%s\n' "$ADDED_LINES" | grep -inF -- "$term" | head -3 || true)
            HIT_PATHS=$(printf '%s\n' "$STAGED_FILES" | grep -iF -- "$term" || true)
            if [ -n "$HIT_LINES" ] || [ -n "$HIT_PATHS" ]; then
                echo -e "${RED}ERROR: Private term \"$term\" found in staged changes.${NC}"
                [ -n "$HIT_PATHS" ] && echo "$HIT_PATHS" | sed 's/^/  path: /'
                [ -n "$HIT_LINES" ] && printf '%s\n' "$HIT_LINES" | cut -c1-160 | sed 's/^/  line: /'
                ERRORS=$((ERRORS + 1))
            fi
        done <<< "$TERMS"
    fi
fi

# Summary
echo ""
if [ $ERRORS -gt 0 ]; then
    echo -e "${RED}Pre-commit check FAILED with $ERRORS error(s).${NC}"
    echo "To bypass (not recommended): git commit --no-verify"
    exit 1
fi

if [ $WARNINGS -gt 0 ]; then
    echo -e "${YELLOW}Pre-commit check passed with $WARNINGS warning(s).${NC}"
else
    echo "Pre-commit check passed."
fi

exit 0
