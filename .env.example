# ===========================================
# Agentbase - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values

# ----- Service Ports -----
# These ports are chosen to avoid conflicts with common services
FRONTEND_PORT=3002
BACKEND_PORT=8002
POSTGRES_PORT=5434

# ----- PostgreSQL Database -----
POSTGRES_USER=agentbase
POSTGRES_PASSWORD=agentbase_password_change_me
POSTGRES_DB=agentbase

# ----- Qdrant Vector Store -----
# Use external Qdrant instance (recommended if you already have one):
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
# Collection name prefix (default: agentbase_)
QDRANT_COLLECTION_PREFIX=

# Or use the included Qdrant (start with: docker-compose --profile with-qdrant up)
# QDRANT_URL=http://qdrant:6333
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# ----- Security -----
# Generate with: openssl rand -hex 32
# If not set, an ephemeral key is generated on startup (sessions won't survive restarts)
SECRET_KEY=

# ----- LLM Providers -----
# Configure at least one provider

# Ollama (local models)
# Default assumes Ollama running on host machine
OLLAMA_BASE_URL=http://host.docker.internal:11434
# On Linux, use: http://172.17.0.1:11434

# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Grok (xAI)
GROK_API_KEY=
GROK_BASE_URL=https://api.x.ai/v1

# Google Gemini
GOOGLE_API_KEY=

# ----- Embedding Providers (optional) -----
# These expand the available embedding models for RAG experimentation

# Cohere (embed-v4, embed-english-v3.0)
COHERE_API_KEY=

# Voyage AI (voyage-3-large, voyage-3, voyage-code-3)
VOYAGE_API_KEY=

# ----- Authentication -----
# Optional: set to require Bearer token auth on /api/ and /mcp routes.
# This is the recommended "global lockdown" mode for any instance exposed
# beyond trusted networks: external requests must present this token (or a
# valid platform API key) or they are rejected.
# Generate with: openssl rand -hex 32
AUTH_TOKEN=

# Optional: your instance's public hostname (e.g. api.example.com) when
# exposed via a tunnel. Setting this activates auth enforcement for
# requests arriving from outside TRUSTED_NETWORKS even without AUTH_TOKEN —
# external clients must then use a platform API key (see POST /api/auth/bootstrap).
EXTERNAL_HOSTNAME=

# Comma-separated CIDR ranges treated as internal/open-access.
# Default: 127.0.0.1/32,::1/128,10.0.0.0/8,192.168.0.0/16
# TRUSTED_NETWORKS=

# Shared secret between nginx and the backend that gates trust of
# X-Forwarded-For / X-Forwarded-Proto headers. Required for any deployment
# that exposes the backend port externally (Tailscale, Cloudflare Tunnel,
# LAN). When unset, the proxy middleware is a no-op — fine for local dev
# but INSECURE for any deployment where the backend port is reachable.
# Generate with: openssl rand -hex 32
# Must be set to the SAME value in both backend and frontend (nginx)
# containers so nginx can inject it and backend can validate it.
INTERNAL_FORWARD_SECRET=

# ----- Default Model Assignments -----
# These can be overridden in the UI per project
DEFAULT_KNOWLEDGE_PROVIDER=anthropic
DEFAULT_KNOWLEDGE_MODEL=claude-sonnet-4-20250514
DEFAULT_CODING_PROVIDER=anthropic
DEFAULT_CODING_MODEL=claude-sonnet-4-20250514

# ----- RAG Configuration -----
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=qwen3-embedding
EMBEDDING_CONCURRENCY=3          # Parallel embedding requests (match OLLAMA_NUM_PARALLEL)
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=5

# ----- Logging -----
LOG_LEVEL=INFO

# ----- Data Isolation (Optional) -----
# By default, data is stored in ./data/ within the repository
# For development with extensions, you may want to store data externally
# to prevent accidental commits. Create docker-compose.override.yml to redirect:
#
#   mkdir -p ~/agentbase-data/{postgres,qdrant,uploads}
#
# See docker-compose.override.yml for volume mount configuration
